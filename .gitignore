# =============================================
# Basketball Player Tracking — .gitignore
# =============================================

# ── Documentation (Private / Not for Git) ──
Doc/

# ── Generated Training Artifacts (recreated at runtime) ──
Code/Final/basketball_project/datasets/
Code/Final/basketball_project/merged_dataset/
Code/Final/basketball_project/extracted_frames/
Code/Final/basketball_project/runs/
Code/Final/basketball_project/outputs/
Code/Final/basketball_project/weights/
Code/Final/runs/

# ── Jupyter Notebook Checkpoints ──
.ipynb_checkpoints/
*/.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Python Cache ──
__pycache__/
*.py[cod]
*$py.class

# ── Virtual Environments ──
venv/
env/
.env/
.venv/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
*.bak

# ── Gradio Temp Files ──
gradio_tmp/
flagged/
