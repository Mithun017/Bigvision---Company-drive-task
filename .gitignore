# =============================================
# Basketball Player Tracking — .gitignore
# =============================================

# ── Documentation (Private / Not for Git) ──
Doc/

# ── YOLO Model Weights (too large for Git) ──
*.pt
*.pth
*.onnx
*.engine
*.torchscript

# ── Video Files (too large for Git) ──
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# ── Dataset & Training Artifacts ──
Code/Final/basketball_project/datasets/
Code/Final/basketball_project/merged_dataset/
Code/Final/basketball_project/extracted_frames/
Code/Final/basketball_project/runs/
Code/Final/basketball_project/outputs/
Code/Final/basketball_project/weights/
Code/Final/runs/

# ── Jupyter Notebook Checkpoints ──
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python Cache ──
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual Environments ──
venv/
env/
.env/
.venv/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── OS Files ──
*.log
*.tmp
*.bak

# ── Gradio Temp Files ──
gradio_tmp/
flagged/

# ── Misc Large / Generated Files ──
Code/Firsrset ups/
Code/MID/
Code/Training_Local.ipynb
Code/absolute_fix.py
Code/colab_final_fix.py
